// Onboard LED (shared with SD MISO — safe when SD not mounted)
#define LED_PIN        2

// ADC (input-only, no camera/SD conflict)
#define ADC_PIN        34

// SD card — SPI mode
#define SD_CS_PIN      13
#define SD_MOSI_PIN    15
#define SD_SCK_PIN     14
#define SD_MISO_PIN    2    // shared with LED — deinit SD before blinking

// I2C — safe pins (21/22 = camera XCLK/PCLK, 26/27 = camera SIOD/SIOC)
#define I2C_SDA        16
#define I2C_SCL        17
#define I2C_FREQ       100000

// Camera — OV2640 on Freenove WROVER
#define CAM_PIN_PWDN   -1
#define CAM_PIN_RESET  -1
#define CAM_PIN_XCLK   21
#define CAM_PIN_SIOD   26
#define CAM_PIN_SIOC   27
#define CAM_PIN_D7     35
#define CAM_PIN_D6     34
#define CAM_PIN_D5     39
#define CAM_PIN_D4     36
#define CAM_PIN_D3     19
#define CAM_PIN_D2     18
#define CAM_PIN_D1     5
#define CAM_PIN_D0     4
#define CAM_PIN_VSYNC  25
#define CAM_PIN_HREF   23
#define CAM_PIN_PCLK   22

// Blink config
#define BLINK_TIMES    6
#define BLINK_DELAY_MS 250

// ─────────────────────────────────────────────────────────────

Preferences prefs;
volatile uint32_t timerCount = 0;
hw_timer_t *diagTimer = NULL;

void IRAM_ATTR onTimer() { timerCount++; }

// ── Helpers ───────────────────────────────────────────────────
void printHeader(const char *title) {
  Serial.println();
  Serial.println("----------------------------------------");
  Serial.printf ("  %s\n", title);
  Serial.println("----------------------------------------");
}
void pass(const char *msg)                  { Serial.printf("  [PASS] %s\n", msg); }
void fail(const char *msg)                  { Serial.printf("  [FAIL] %s\n", msg); }
void warn(const char *msg)                  { Serial.printf("  [WARN] %s\n", msg); }
void info(const char *lbl, const char *val) { Serial.printf("         %-26s %s\n", lbl, val); }
void infoU(const char *lbl, uint32_t v, const char *u = "") {
  Serial.printf("         %-26s %u %s\n", lbl, v, u);
}

// ════════════════════════════════════════════════════════════
//  TEST 1 — CHIP INFO
// ════════════════════════════════════════════════════════════
void testChipInfo() {
  printHeader("1 . CHIP INFO");

  esp_chip_info_t chip;
  esp_chip_info(&chip);

  const char *model = "Unknown";
  switch (chip.model) {
    case CHIP_ESP32:   model = "ESP32 (WROVER)"; break;
    case CHIP_ESP32S2: model = "ESP32-S2";       break;
    case CHIP_ESP32S3: model = "ESP32-S3";       break;
    case CHIP_ESP32C3: model = "ESP32-C3";       break;
    default:           model = "Other";          break;
  }
  info("Model:",          model);
  infoU("CPU cores:",     chip.cores);
  infoU("CPU frequency:", getCpuFrequencyMhz(), "MHz");
  infoU("Chip revision:", chip.revision);
  info("SDK version:",    ESP.getSdkVersion());

  char feat[80] = "";
  if (chip.features & CHIP_FEATURE_WIFI_BGN)  strcat(feat, "WiFi ");
  if (chip.features & CHIP_FEATURE_BT)        strcat(feat, "BT ");
  if (chip.features & CHIP_FEATURE_BLE)       strcat(feat, "BLE ");
  if (chip.features & CHIP_FEATURE_EMB_FLASH) strcat(feat, "EmbFlash ");
  if (strlen(feat) == 0) strcat(feat, "(none)");
  info("Features:", feat);

  uint8_t mac[6];
  esp_read_mac(mac, ESP_MAC_WIFI_STA);
  char macStr[20];
  snprintf(macStr, sizeof(macStr), "%02X:%02X:%02X:%02X:%02X:%02X",
           mac[0], mac[1], mac[2], mac[3], mac[4], mac[5]);
  info("WiFi MAC:", macStr);

  pass("Chip info OK");
}

