// ════════════════════════════════════════════════════════════
//  SETUP / LOOP
// ════════════════════════════════════════════════════════════
void setup() {
  Serial.begin(115200);
  delay(800);

  Serial.println();
  Serial.println("========================================");
  Serial.println("  ESP32 WROVER DIAGNOSTIC SKETCH");
  Serial.println("  Freenove WROVER  |  Arduino Core v3");
  Serial.printf ("  SDK:   %s\n", ESP.getSdkVersion());
  Serial.printf ("  Built: %s  %s\n", __DATE__, __TIME__);
  Serial.println("========================================");

  testChipInfo();       //  1
  testMemory();         //  2
  testPSRAMStress();    //  3  — big PSRAM alloc
  testTemperature();    //  4
  testADC();            //  5
  testGPIO();           //  6  — LED blink BEFORE SD init (GPIO2 shared)
  testWiFi();           //  7
  testBluetooth();      //  8
  testTimer();          //  9
  testPreferences();    // 10
  testSD();             // 11  — SD.end() called inside; GPIO2 freed after
  testCamera();         // 12  — camera deinit called inside
  testI2C();            // 13  — GPIO16/17 only
  testTouchPins();      // 14  — skips camera-conflicted pins

  printSummary();
}

void loop() {
  // Heartbeat so you know the board is alive after diagnostics
  digitalWrite(LED_PIN, HIGH); delay(800);
  digitalWrite(LED_PIN, LOW);  delay(800);
}
