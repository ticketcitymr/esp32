}

// ════════════════════════════════════════════════════════════
//  TEST 3 — PSRAM STRESS TEST
//  Allocates a 4 MB buffer in PSRAM, writes a walking pattern,
//  reads it back, and verifies. Confirms PSRAM is functional.
// ════════════════════════════════════════════════════════════
void testPSRAMStress() {
  printHeader("3 . PSRAM STRESS TEST  (4 MB alloc + verify)");

  if (!psramFound()) {
    warn("PSRAM not found — skipping stress test");
    return;
  }

  const size_t TEST_SIZE = 4 * 1024 * 1024;  // 4 MB
  Serial.printf("         Allocating %u MB in PSRAM...\n", (unsigned)(TEST_SIZE / (1024*1024)));

  uint8_t *buf = (uint8_t *)ps_malloc(TEST_SIZE);
  if (!buf) {
    fail("ps_malloc failed — PSRAM may not be enabled or is defective");
    return;
  }
  infoU("Buffer address:", (uint32_t)(uintptr_t)buf);
  Serial.println("         Writing pattern...");

  // Write walking byte pattern
  for (size_t i = 0; i < TEST_SIZE; i++) buf[i] = (uint8_t)(i & 0xFF);

  Serial.println("         Verifying pattern...");
  size_t errors = 0;
  for (size_t i = 0; i < TEST_SIZE; i++) {
    if (buf[i] != (uint8_t)(i & 0xFF)) errors++;
  }

  free(buf);

  if (errors == 0) {
    pass("4 MB PSRAM write/read — zero errors");
  } else {
    char msg[48];
    snprintf(msg, sizeof(msg), "%u byte errors — PSRAM may be faulty", (unsigned)errors);
    fail(msg);
  }
}

// ════════════════════════════════════════════════════════════
//  TEST 4 — INTERNAL TEMPERATURE
// ════════════════════════════════════════════════════════════
void testTemperature() {
  printHeader("4 . INTERNAL TEMPERATURE SENSOR");

  float tempC = temperatureRead();
  if (isnan(tempC)) {
    fail("Sensor returned NaN");
  } else {
    char buf[48];
    snprintf(buf, sizeof(buf), "%.1f C  /  %.1f F", tempC, tempC * 9.0f / 5.0f + 32.0f);
    info("Die temperature:", buf);
    (tempC > 0 && tempC < 120) ? pass("Temperature plausible") : fail("Out of expected range");
  }
}

// ════════════════════════════════════════════════════════════
//  TEST 5 — ADC
// ════════════════════════════════════════════════════════════
void testADC() {
  printHeader("5 . ADC  (GPIO34 — floating, input-only)");

  analogReadResolution(12);
  analogSetAttenuation(ADC_11db);

  uint32_t sum = 0;
  for (int i = 0; i < 16; i++) { sum += analogRead(ADC_PIN); delay(5); }
  uint32_t avg = sum / 16;

  infoU("GPIO:", ADC_PIN);
  infoU("12-bit avg:", avg, "(0-4095, float = noise, OK)");
  infoU("Approx mV:", (avg * 3300UL) / 4095, "mV");
  pass("ADC read complete");
}

// ════════════════════════════════════════════════════════════
//  TEST 6 — GPIO / LED BLINK
//  GPIO2 = LED = SD MISO.  SD must be deinitialized first.
//  testSD() calls SD.end() before returning, so order is:
//  testGPIO() runs BEFORE testSD() in setup() intentionally.
// ════════════════════════════════════════════════════════════
void testGPIO() {
  printHeader("6 . GPIO / LED BLINK  (GPIO2)");

  info("Note:", "GPIO2 = onboard LED = SD MISO (shared)");
  info("       ", "LED test runs before SD init to avoid conflict");

  pinMode(LED_PIN, OUTPUT);
  Serial.printf("         Blinking %d times...\n", BLINK_TIMES);
  for (int i = 0; i < BLINK_TIMES; i++) {
    digitalWrite(LED_PIN, HIGH); delay(BLINK_DELAY_MS);
    digitalWrite(LED_PIN, LOW);  delay(BLINK_DELAY_MS);
  }
  pass("GPIO blink done");
}

// ════════════════════════════════════════════════════════════
//  TEST 7 — WIFI SCAN
// ════════════════════════════════════════════════════════════
void testWiFi() {
  printHeader("7 . WiFi SCAN");

  WiFi.mode(WIFI_STA);
  WiFi.disconnect();
  delay(100);

  Serial.println("         Scanning...");
  int n = WiFi.scanNetworks();
  if (n < 0) { fail("Scan failed"); return; }

  char buf[12]; snprintf(buf, sizeof(buf), "%d", n);
  info("Networks found:", buf);

  for (int i = 0; i < min(n, 5); i++) {
    Serial.printf("           [%d] RSSI %-4d  Ch %-2d  %s\n",
                  i + 1, WiFi.RSSI(i), WiFi.channel(i), WiFi.SSID(i).c_str());
  }
  if (n > 5) Serial.printf("           ... and %d more\n", n - 5);
  WiFi.scanDelete();
  pass("WiFi scan OK");
}

