// ════════════════════════════════════════════════════════════
//  TEST 9 — HARDWARE TIMER  (v3 API)
// ════════════════════════════════════════════════════════════
void testTimer() {
  printHeader("9 . HARDWARE TIMER  (v3 API)");

  timerCount = 0;
  diagTimer = timerBegin(1000000);
  timerAttachInterrupt(diagTimer, &onTimer);
  timerAlarm(diagTimer, 1000000, true, 0);

  Serial.println("         Waiting ~2.1 s...");
  delay(2100);
  timerEnd(diagTimer);

  infoU("ISR fires in 2.1 s:", timerCount, "(expect 2)");
  (timerCount >= 2) ? pass("Timer ISR working") : fail("Timer did not fire correctly");
}

// ════════════════════════════════════════════════════════════
//  TEST 10 — NVS PREFERENCES
// ════════════════════════════════════════════════════════════
void testPreferences() {
  printHeader("10 . NVS PREFERENCES");

  const uint32_t MAGIC = 0xDEADBEEF;
  prefs.begin("diag", false);
  prefs.putUInt("magic", MAGIC);
  uint32_t rb = prefs.getUInt("magic", 0);
  prefs.remove("magic");
  prefs.end();

  char buf[16]; snprintf(buf, sizeof(buf), "0x%08X", rb);
  info("Read back:", buf);
  (rb == MAGIC) ? pass("NVS round-trip OK") : fail("NVS mismatch — flash issue?");
}

// ════════════════════════════════════════════════════════════
//  TEST 11 — SD CARD
//  Uses SPI mode.  Freenove WROVER wiring:
//    CS=GPIO13  MOSI=GPIO15  SCK=GPIO14  MISO=GPIO2
//  Writes a test file, reads it back, verifies, then removes it.
//  Calls SD.end() when done so GPIO2 can be used again.
// ════════════════════════════════════════════════════════════
void testSD() {
  printHeader("11 . SD CARD");

  info("CS:",   "GPIO13");
  info("MOSI:", "GPIO15");
  info("SCK:",  "GPIO14");
  info("MISO:", "GPIO2  (shared with onboard LED)");

  SPI.begin(SD_SCK_PIN, SD_MISO_PIN, SD_MOSI_PIN, SD_CS_PIN);

  if (!SD.begin(SD_CS_PIN)) {
    fail("SD mount failed — check card is inserted and formatted FAT32");
    SPI.end();
    return;
  }

  // Card type
  uint8_t cardType = SD.cardType();
  const char *typeStr = "Unknown";
  switch (cardType) {
    case CARD_MMC:  typeStr = "MMC";      break;
    case CARD_SD:   typeStr = "SD";       break;
    case CARD_SDHC: typeStr = "SDHC";     break;
    case CARD_NONE: typeStr = "NONE";     break;
  }
  info("Card type:", typeStr);
  infoU("Card size:", (uint32_t)(SD.cardSize() / (1024*1024)), "MB");
  infoU("Total space:", (uint32_t)(SD.totalBytes() / (1024*1024)), "MB");
  infoU("Used space:", (uint32_t)(SD.usedBytes() / (1024*1024)), "MB");

  if (cardType == CARD_NONE) {
    fail("No SD card detected");
    SD.end(); SPI.end();
    return;
  }

  // Write test
  const char *testPath = "/diag_test.txt";
  const char *testData = "ESP32-WROVER DIAG OK 0xDEADBEEF";

  File f = SD.open(testPath, FILE_WRITE);
  if (!f) {
    fail("Could not open file for writing");
    SD.end(); SPI.end();
    return;
  }
  f.print(testData);
  f.close();
  pass("File write OK");

  // Read back and verify
  f = SD.open(testPath, FILE_READ);
  if (!f) {
    fail("Could not open file for reading");
    SD.end(); SPI.end();
    return;
  }
  char readBuf[64] = {0};
  int bytesRead = f.readBytes(readBuf, sizeof(readBuf) - 1);
  f.close();

  infoU("Bytes read back:", (uint32_t)bytesRead);
  info("Content:", readBuf);

  if (strcmp(readBuf, testData) == 0) {
    pass("SD write/read/verify — content matches");
  } else {
    fail("SD content mismatch");
  }

  // Cleanup
  SD.remove(testPath);
  SD.end();
  SPI.end();
  pass("SD test complete, card unmounted");
}

// ════════════════════════════════════════════════════════════
//  TEST 12 — CAMERA  (OV2640)
//  Initialises the camera, captures one frame at QVGA,
//  reports the compressed JPEG size, then deinitialises.
//  Full PSRAM must be enabled — frame buffer lives in PSRAM.
// ════════════════════════════════════════════════════════════
void testCamera() {
  printHeader("12 . CAMERA  (OV2640 via esp_camera)");

  if (!psramFound()) {
    fail("PSRAM not found — camera requires PSRAM. Enable in Tools > PSRAM.");
    return;
  }

  camera_config_t config;
  config.ledc_channel = LEDC_CHANNEL_0;
  config.ledc_timer   = LEDC_TIMER_0;
  config.pin_d0       = CAM_PIN_D0;
  config.pin_d1       = CAM_PIN_D1;
  config.pin_d2       = CAM_PIN_D2;
  config.pin_d3       = CAM_PIN_D3;
  config.pin_d4       = CAM_PIN_D4;
  config.pin_d5       = CAM_PIN_D5;
  config.pin_d6       = CAM_PIN_D6;
  config.pin_d7       = CAM_PIN_D7;
  config.pin_xclk     = CAM_PIN_XCLK;
  config.pin_pclk     = CAM_PIN_PCLK;
  config.pin_vsync    = CAM_PIN_VSYNC;
  config.pin_href     = CAM_PIN_HREF;
  config.pin_sccb_sda = CAM_PIN_SIOD;
  config.pin_sccb_scl = CAM_PIN_SIOC;
  config.pin_pwdn     = CAM_PIN_PWDN;
  config.pin_reset    = CAM_PIN_RESET;
  config.xclk_freq_hz = 20000000;          // 20 MHz XCLK
  config.pixel_format = PIXFORMAT_JPEG;    // JPEG = smaller buffer
  config.frame_size   = FRAMESIZE_QVGA;    // 320x240 for quick test
  config.jpeg_quality = 12;                // 0=best, 63=worst
  config.fb_count     = 1;
  config.fb_location  = CAMERA_FB_IN_PSRAM;
  config.grab_mode    = CAMERA_GRAB_WHEN_EMPTY;

  Serial.println("         Initialising OV2640...");
  esp_err_t err = esp_camera_init(&config);
  if (err != ESP_OK) {
    char msg[64];
    snprintf(msg, sizeof(msg), "esp_camera_init failed: 0x%x", err);
    fail(msg);
    Serial.println("         Common causes: no camera connected, wrong pin map,");
    Serial.println("         PSRAM disabled, or wrong board selected.");
    return;
  }
  pass("Camera init OK");

  // Get sensor info
  sensor_t *s = esp_camera_sensor_get();
  if (s) {
    char buf[32];
    snprintf(buf, sizeof(buf), "0x%02X", s->id.PID);
    info("Sensor PID:", buf);
    info("Expected OV2640:", "0x26");
    (s->id.PID == 0x26) ? pass("OV2640 confirmed") : warn("Different sensor detected — check camera module");
  }

  // Capture a frame
  Serial.println("         Capturing QVGA JPEG frame...");
  camera_fb_t *fb = esp_camera_fb_get();
  if (!fb) {
    fail("Frame capture failed — buffer empty");
    esp_camera_deinit();
    return;
  }

  infoU("Frame width:",  fb->width,  "px");
  infoU("Frame height:", fb->height, "px");
  infoU("JPEG size:",    fb->len,    "bytes");
  infoU("Timestamp:",    (uint32_t)fb->timestamp.tv_sec);

  bool sizeOK = (fb->len > 1000 && fb->len < 200000);
  esp_camera_fb_return(fb);
  esp_camera_deinit();

  sizeOK ? pass("Frame captured — JPEG size looks valid") :
           fail("Frame size suspicious — may be corrupt");
}

// ════════════════════════════════════════════════════════════
//  TEST 13 — I2C SCANNER
//  WROVER camera occupies GPIO21,22 (XCLK/PCLK) and
//  GPIO26,27 (SIOD/SIOC).  Only GPIO16/17 are safe here.
// ════════════════════════════════════════════════════════════
void testI2C() {
  printHeader("13 . I2C SCANNER");

  warn("GPIO21,22,26,27 used by camera — only scanning GPIO16/17");
  Serial.printf("\n         SDA=GPIO%d  SCL=GPIO%d  @ %d kHz\n\n",
                I2C_SDA, I2C_SCL, I2C_FREQ / 1000);

  Wire.begin(I2C_SDA, I2C_SCL, I2C_FREQ);
  delay(50);

  int found = 0;
  for (uint8_t addr = 0x08; addr <= 0x77; addr++) {
    Wire.beginTransmission(addr);
    uint8_t err = Wire.endTransmission();
    if (err == 0) {
      const char *name = "";
      switch (addr) {
        case 0x20: name = " (PCF8574 / MCP23017)";  break;
        case 0x27: name = " (PCF8574 LCD)";          break;
        case 0x29: name = " (VL53L0X / TCS34725)";  break;
        case 0x3C: name = " (SSD1306 OLED)";         break;
        case 0x3D: name = " (SSD1306 OLED alt)";     break;
        case 0x40: name = " (INA219 / PCA9685)";     break;
        case 0x48: name = " (ADS1115 ADDR=GND)";     break;
        case 0x49: name = " (ADS1115 ADDR=VCC)";     break;
        case 0x4A: name = " (ADS1115 ADDR=SDA)";     break;
        case 0x4B: name = " (ADS1115 ADDR=SCL)";     break;
        case 0x57: name = " (ATSHA204A)";             break;
        case 0x68: name = " (MPU6050 / DS3231)";     break;
        case 0x69: name = " (MPU6050 AD0=1)";        break;
        case 0x70: name = " (TCA9548A mux)";          break;
        case 0x76: name = " (BME280/680/688 0x76)";  break;
        case 0x77: name = " (BME280/680/688 0x77)";  break;
      }
      Serial.printf("           FOUND  0x%02X%s\n", addr, name);
      found++;
    } else if (err == 4) {
      Serial.printf("           ERROR  0x%02X  (check pull-ups)\n", addr);
    }
  }
  Wire.end();

  if (found == 0) Serial.println("           (no devices responded on GPIO16/17)");
  else            Serial.printf("           --> %d device(s) found\n", found);
  Serial.println();

  char buf[40];
  snprintf(buf, sizeof(buf), "%d device(s) found on GPIO16/17", found);
  pass(buf);
}

// ════════════════════════════════════════════════════════════
//  TEST 14 — CAPACITIVE TOUCH PINS
//  Classic ESP32 touch GPIOs: T0=4, T1=0, T2=2, T3=15,
//  T4=13, T5=12, T6=14, T7=27, T8=33, T9=32
//
//  WROVER conflicts:
//    T0 = GPIO4  → Camera D0 — SKIPPED
//    T2 = GPIO2  → SD MISO / LED — reported, still read (SD unmounted)
//    T7 = GPIO27 → Camera SIOC — SKIPPED
//  Safe for floating read: T1,T2,T3,T4,T5,T6,T8,T9
// ════════════════════════════════════════════════════════════
void testTouchPins() {
  printHeader("14 . CAPACITIVE TOUCH PINS");

  Serial.println("         ESP32-WROVER classic touch map:");
  Serial.println("         T0=GPIO4  (SKIP — camera D0)");
  Serial.println("         T7=GPIO27 (SKIP — camera SIOC)");
  Serial.println("         T2=GPIO2  (NOTE — SD MISO/LED, SD unmounted)");
  Serial.println();
  Serial.printf("         %-5s  %-6s  %-10s  Status\n", "Name", "GPIO", "Raw Count");
  Serial.println("         -----  ------  ----------  ------");

  struct TouchPin { const char *name; uint8_t gpio; bool skip; const char *note; };
  const TouchPin pins[] = {
    {"T0", 4,  true,  "SKIP (camera D0)"},
    {"T1", 0,  false, ""},
    {"T2", 2,  false, "NOTE:SD MISO"},
    {"T3", 15, false, ""},
    {"T4", 13, false, "NOTE:SD CS"},
    {"T5", 12, false, ""},
    {"T6", 14, false, "NOTE:SD SCK"},
    {"T7", 27, true,  "SKIP (camera SIOC)"},
    {"T8", 33, false, ""},
    {"T9", 32, false, ""},
  };

  int tested = 0, responsive = 0;
  for (int i = 0; i < 10; i++) {
    if (pins[i].skip) {
      Serial.printf("         %-5s  GPIO%-2d  %-10s  %s\n",
                    pins[i].name, pins[i].gpio, "---", pins[i].note);
      continue;
    }

    uint32_t sum = 0;
    for (int s = 0; s < 4; s++) { sum += touchRead(pins[i].gpio); delay(5); }
    uint32_t avg = sum / 4;

    uint8_t bars = (uint8_t)min((uint32_t)20, avg / 2000);
    char bar[22] = {0};
    for (int b = 0; b < bars; b++) bar[b] = '#';

    Serial.printf("         %-5s  GPIO%-2d  %-10u  |%s  %s\n",
                  pins[i].name, pins[i].gpio, avg, bar,
                  strlen(pins[i].note) ? pins[i].note : "");

    tested++;
    if (avg > 0) responsive++;
  }

  Serial.println();
  Serial.println("         Tip: hold a wire to any pin and watch value drop.");
  char buf[48];
  snprintf(buf, sizeof(buf), "%d / %d tested touch pins responded", responsive, tested);
  (responsive == tested) ? pass(buf) : fail(buf);
}

